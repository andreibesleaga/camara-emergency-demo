{
  "name": "camara-emergency-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "cd backend && tsc",
    "build:full": "npm run build:frontend && npm run build:backend",
    "start": "node backend/dist/server.js",
    "dev": "concurrently \"cd backend && ts-node-dev --respawn --transpile-only server.ts\" \"cd frontend && vite\"",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.17"
  },
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "axios": "^1.17.0",
    "camara-mcp": "^0.9.2",
    "camara-sdk": "^0.15.0",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "leaflet-draw": "^1.0.4",
    "ngeohash": "^0.6.3",
    "node-schedule": "^2.1.1",
    "react-chartjs-2": "^5.3.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/leaflet-draw": "^1.0.13",
    "@types/ngeohash": "^0.6.8",
    "@types/node": "^25.9.2",
    "@types/node-schedule": "^2.1.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/winston": "^2.4.4",
    "@vitejs/plugin-react": "^6.0.2",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
